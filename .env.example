# Root environment configuration
# These are global defaults shared across all apps and the runtime.
# Per-app settings should go in apps/<app-name>/app.env instead.

# === Cluster/Runtime Configuration ===
PROFILE=k3d                      # Runtime profile: k3d, aks, eks (controls which tools are installed)
CLUSTER_NAME=sagars-cluster      # Name of the k3d/cloud cluster
HTTP_PORT=80                     # Host port to expose HTTP (ingress traffic)
HTTPS_PORT=443                   # Host port to expose HTTPS (ingress traffic)

# === Global Defaults ===
# These can be overridden per-app by setting them in apps/<app-name>/app.env
# APP_NAME=go-api                # Default app (can override via make APP_NAME=foo)
# HELM_RELEASE_NAME=go-api       # Default Helm release name (usually matches app name)
# HELM_VALUES=values-dev.yaml    # Default values file for Helm deployments

# === Platform Provider Selection ===
# Each category can have multiple providers. Change the value and re-run platform-up.
INGRESS_PROVIDER=traefik         # traefik | nginx
METRICS_PROVIDER=prometheus      # prometheus | victoria-metrics
# LOGGING_PROVIDER=loki          # loki | elasticsearch (Phase 2)
# TRACING_PROVIDER=tempo         # tempo | jaeger (Phase 2)
# GITOPS_PROVIDER=argocd         # argocd | flux (Phase 3)
# CHAOS_PROVIDER=chaos-mesh      # chaos-mesh | litmus (Phase 5)
# POLICY_PROVIDER=kyverno        # kyverno | opa-gatekeeper (Phase 4)
# SECRETS_PROVIDER=sealed-secrets # sealed-secrets | external-secrets (Phase 4)

# === Cloud Runtime Configuration (only needed for PROFILE=aks or eks) ===
# Azure (AKS)
# AZURE_RESOURCE_GROUP=sagars-lab-rg
# AZURE_LOCATION=eastus
# AZURE_ACR_NAME=sagarslab

# AWS (EKS)
# AWS_REGION=us-east-1
# AWS_ECR_ACCOUNT_ID=123456789012
# AWS_ECR_REPO_PREFIX=sagars-lab
