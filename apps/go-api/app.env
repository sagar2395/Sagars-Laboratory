# Application-specific configuration
# This file is automatically sourced by the makefile and strategy scripts.

# name of the app directory (must match parent folder)
APP_NAME=go-api

# build strategy should correspond to a script under engine/build/
# current options: docker (uses engine/build/docker.sh)
BUILD_STRATEGY=docker

# deploy strategy corresponds to a script under engine/deploy/
DEPLOY_STRATEGY=helm

# helm-specific settings (required by helm.sh)
HELM_RELEASE_NAME=go-api
HELM_VALUES=values-dev.yaml

# optional namespace; defaults to APP_NAME if unset
# NAMESPACE=go-api
