# Template for per-application environment configuration.
# Copy this to apps/<new-app>/app.env and customize for your application.
#
# This file is automatically sourced by:
#   - engine/build.sh (to discover BUILD_STRATEGY)
#   - engine/deploy.sh (to discover DEPLOY_STRATEGY)
#   - engine/run.sh (optional: for local execution)
#   - strategy scripts in engine/build/ and engine/deploy/
#
# Syntax: KEY=VALUE (no spaces around =)
# Comments: start with #

# === Required: Application Identity ===
APP_NAME=myapp                           # must match parent folder name

# === Required: Build Configuration ===
BUILD_STRATEGY=docker                    # Build strategy: docker, golang, binary, lambda-zip, etc.
                                         # (strategy script will be engine/build/${BUILD_STRATEGY}.sh)

# === Required: Deployment Configuration ===
DEPLOY_STRATEGY=helm                     # Deploy strategy: helm, kustomize, lambda, vm, etc.
                                         # (strategy script will be engine/deploy/${DEPLOY_STRATEGY}.sh)

# === For Helm Deployments ===
HELM_RELEASE_NAME=myapp                  # Helm release name (usually app name)
HELM_VALUES=values-dev.yaml              # Which values file to use (dev, test, prod-like, etc.)
NAMESPACE=myapp                          # Kubernetes namespace (defaults to APP_NAME if unset)

# === Optional: Docker/Build Settings ===
# DOCKERFILE=Dockerfile                  # Dockerfile path (defaults to apps/<app>/Dockerfile)
# DOCKER_REGISTRY=myregistry.azurecr.io  # Container registry (for pushing images)
# DOCKER_IMAGE_TAG=v1.0.0                # Image tag (defaults to 'latest')

# === Optional: Resource Quotas / Limits ===
# MEMORY_REQUEST=128Mi                   # Pod memory request
# MEMORY_LIMIT=512Mi                     # Pod memory limit
# CPU_REQUEST=50m                        # Pod CPU request
# CPU_LIMIT=500m                         # Pod CPU limit

# === Optional: Replica Configuration ===
# REPLICAS=3                             # Number of pod replicas for deployment
# AUTO_SCALE=true                        # Enable horizontal pod autoscaler
# HPA_MIN_REPLICAS=2                     # Minimum replicas for HPA
# HPA_MAX_REPLICAS=10                    # Maximum replicas for HPA
# HPA_TARGET_CPU=70                      # Target CPU utilization for HPA

# === Optional: Ingress Settings ===
# INGRESS_ENABLED=true                   # Create an ingress resource
# INGRESS_HOSTNAME=myapp.k3d.local       # Hostname for ingress
# INGRESS_TLAB=traefik                   # Ingress class (traefik, nginx, etc.)

# === Optional: Logging & Monitoring ===
# LOG_LEVEL=info                         # Application log level
# METRICS_ENABLED=true                   # Enable Prometheus metrics
# TRACING_ENABLED=false                  # Enable distributed tracing
