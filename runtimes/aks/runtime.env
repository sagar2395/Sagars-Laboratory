# AKS runtime-specific defaults
# Loaded by labctl and platform scripts to resolve runtime-specific values.

INGRESS_CLASS=nginx
STORAGE_CLASS=managed-csi
DOMAIN_SUFFIX=sagarslab.io
REGISTRY_TYPE=acr

# Azure-specific
AZURE_RESOURCE_GROUP=sagars-lab-rg
AZURE_LOCATION=eastus
AZURE_ACR_NAME=sagarslab
