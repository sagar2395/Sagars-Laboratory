# Tool Versions Configuration
# Explicit versions allow reproducible builds and testing across multiple versions.
# Update these to test compatibility or pin to stable versions.
# Last updated: March 2026

# Kubernetes
# kubectl releases: https://github.com/kubernetes/kubernetes/releases
KUBECTL_VERSION=1.29.3

# k3d (Kubernetes in Docker)
# k3d releases: https://github.com/k3d-io/k3d/releases
K3D_VERSION=5.8.3

# Azure CLI (for AKS)
# az cli releases: https://docs.microsoft.com/en-us/cli/azure/release-notes
AZ_CLI_VERSION=2.57.0

# Docker
# docker releases: https://docs.docker.com/engine/release-notes/
DOCKER_VERSION=29.2.1

# Helm
# helm releases: https://github.com/helm/helm/releases
HELM_VERSION=3.14.0

# Terraform (for cloud runtimes: AKS, EKS)
# terraform releases: https://github.com/hashicorp/terraform/releases
TERRAFORM_VERSION=1.7.0

# AWS CLI (for EKS)
# aws cli releases: https://github.com/aws/aws-cli/releases
AWS_CLI_VERSION=2
